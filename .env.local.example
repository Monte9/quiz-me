# Neon Postgres pooled connection string. Get from Vercel → Project →
# Storage → Neon, or directly from console.neon.tech.
DATABASE_URL=postgres://user:password@host/db?sslmode=require

# Anthropic API key for quiz generation + grading. Only needed at
# runtime (not in CI — the migration workflow doesn't call Claude).
ANTHROPIC_API_KEY=sk-ant-...
